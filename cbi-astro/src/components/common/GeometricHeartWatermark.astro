---
interface Props {
	class?: string
}

const {
	class: className =
		"pointer-events-none absolute left-1/2 top-1/2 z-1 w-[min(120vw,720px)] -translate-x-1/2 -translate-y-1/2 rotate-[-14deg] text-white opacity-[0.04]",
} = Astro.props
---

<!-- Faceted / origami-style heart silhouette (watermark) -->
<svg
	class={className}
	viewBox="0 0 240 220"
	fill="currentColor"
	aria-hidden="true">
	<path d="M120 205 15 85 50 28 120 98 190 28 225 85 120 205Z"></path>
</svg>
