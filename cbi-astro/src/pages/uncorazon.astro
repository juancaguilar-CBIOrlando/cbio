---
import Layout from "@/layouts/Layout.astro"
import UnCorazonHero from "@/components/uncorazon/UnCorazonHero.astro"
import UnCorazonVision from "@/components/uncorazon/UnCorazonVision.astro"
import UnCorazonGoals from "@/components/uncorazon/UnCorazonGoals.astro"
import UnCorazonFAQ from "@/components/uncorazon/UnCorazonFAQ.astro"
import UnCorazonParticipate from "@/components/uncorazon/UnCorazonParticipate.astro"
---

<Layout title="Un Corazón Para Su Casa - CBI Orlando" navLogo="black">
	<div class="uncorazon-page">
		<UnCorazonHero />
		<UnCorazonVision />
		<UnCorazonGoals />
		<UnCorazonFAQ />
		<UnCorazonParticipate />
		<a
			href="https://pushpay.com/g/cbiorlando"
			target="_blank"
			rel="noopener noreferrer"
			class="uncorazon-floating-cta"
			aria-label="Donar Ahora">
			Donar Ahora
		</a>
	</div>
</Layout>

<style is:global>
	html:has(.uncorazon-page) {
		scroll-behavior: smooth;
	}

	.uncorazon-page {
		--campaign-navy: #161e57;
		--campaign-gold: #fcd22a;
		--campaign-gold-soft: #fcd22a33;
		--campaign-cream: #faf8f2;
		--campaign-green: #2eb576;
	}

	.uncorazon-floating-cta {
		position: fixed;
		bottom: 1.5rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 50;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 2rem;
		background-color: var(--campaign-gold);
		color: var(--campaign-navy);
		font-family: "Bebas Neue", sans-serif;
		font-size: 1.15rem;
		letter-spacing: 0.12em;
		border-radius: 0.25rem;
		box-shadow:
			0 4px 20px rgba(252, 210, 42, 0.35),
			0 2px 8px rgba(0, 0, 0, 0.1);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			background-color 0.25s ease;
		-webkit-tap-highlight-color: transparent;
	}

	.uncorazon-floating-cta:hover {
		transform: translateX(-50%) translateY(-4px);
		box-shadow:
			0 8px 32px rgba(252, 210, 42, 0.5),
			0 4px 12px rgba(0, 0, 0, 0.12);
		background-color: #fdd940;
	}

	.uncorazon-floating-cta:active {
		transform: translateX(-50%) translateY(0);
	}
</style>
