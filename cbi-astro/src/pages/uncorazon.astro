---
import Layout from "@/layouts/Layout.astro"
import UnCorazonHero from "@/components/uncorazon/UnCorazonHero.astro"
import UnCorazonVision from "@/components/uncorazon/UnCorazonVision.astro"
import UnCorazonGoals from "@/components/uncorazon/UnCorazonGoals.astro"
---

<Layout title="Un Corazón Para Su Casa - CBI Orlando" navLogo="white">
	<div class="uncorazon-page">
		<UnCorazonHero />
		<UnCorazonVision />
		<UnCorazonGoals />
	</div>
</Layout>

<script>
	const prefersReduced =
		typeof window !== "undefined" &&
		window.matchMedia("(prefers-reduced-motion: reduce)").matches
	if (!prefersReduced) {
		const nodes = document.querySelectorAll(".uncorazon-page .reveal")
		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						e.target.classList.add("visible")
						io.unobserve(e.target)
					}
				}
			},
			{ rootMargin: "0px 0px -12% 0px", threshold: 0.12 },
		)
		nodes.forEach((n) => io.observe(n))
	} else {
		document.querySelectorAll(".uncorazon-page .reveal").forEach((el) => {
			el.classList.add("visible")
		})
	}
</script>

<style is:global>
	.uncorazon-page {
		--campaign-navy: #161e57;
		--campaign-gold: #fcd22a;
		--campaign-gold-soft: #fcd22a33;
		--campaign-cream: #faf8f2;
	}
</style>
