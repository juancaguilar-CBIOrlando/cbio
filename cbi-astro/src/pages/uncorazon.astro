---
import Layout from "@/layouts/Layout.astro"
import UnCorazonHero from "@/components/uncorazon/UnCorazonHero.astro"
import UnCorazonVision from "@/components/uncorazon/UnCorazonVision.astro"
import UnCorazonGoals from "@/components/uncorazon/UnCorazonGoals.astro"
import UnCorazonFAQ from "@/components/uncorazon/UnCorazonFAQ.astro"
import UnCorazonParticipate from "@/components/uncorazon/UnCorazonParticipate.astro"
---

<Layout title="Un Corazón Para Su Casa - CBI Orlando" navLogo="white">
	<div class="uncorazon-page">
		<UnCorazonHero />
		<UnCorazonVision />
		<UnCorazonGoals />
		<UnCorazonFAQ />
		<UnCorazonParticipate />
	</div>
</Layout>

<style is:global>
	html:has(.uncorazon-page) {
		scroll-behavior: smooth;
	}

	@media (prefers-reduced-motion: reduce) {
		html:has(.uncorazon-page) {
			scroll-behavior: auto;
		}
	}

	.uncorazon-page {
		--campaign-navy: #161e57;
		--campaign-gold: #fcd22a;
		--campaign-gold-soft: #fcd22a33;
		--campaign-cream: #faf8f2;
	}
</style>
